{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://look-twice.dev/schemas/purify_command_v1.schema.json",
  "title": "Purify Robotics NDJSON Command v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_id", "op", "payload"],
  "properties": {
    "schema_version": {"const": "purify.robotics.command.v1"},
    "request_id": {"type": "string", "minLength": 1},
    "op": {"enum": ["evaluate_action", "invalidate_plan"]},
    "payload": {"type": "object"}
  }
}
