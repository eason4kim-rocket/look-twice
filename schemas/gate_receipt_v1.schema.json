{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://look-twice.dev/schemas/gate_receipt_v1.schema.json",
  "title": "Purify Robotics Gate Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "receipt_id", "contract_id", "action", "fact_id",
    "predicate", "scope", "evaluated_step", "valid_until_step", "admitted",
    "decision", "p_blocked", "prediction_set", "calibration_artifact_id",
    "calibration_applicable", "clauses", "used_claim_ids",
    "discounted_claims", "measurement_root_ids", "device_root_ids",
    "unresolved_conflicts", "belief_gaps", "assumptions", "receipt_sha256"
  ],
  "properties": {
    "schema_version": {"const": "purify.robotics.gate-receipt/v1"},
    "receipt_id": {"type": "string", "pattern": "^gate:[0-9a-f]{16}$"},
    "contract_id": {"type": "string", "minLength": 1},
    "action": {"type": "string", "minLength": 1},
    "fact_id": {"type": "string", "minLength": 1},
    "predicate": {"type": "string", "minLength": 1},
    "scope": {"$ref": "robot_claim_v1.schema.json#/$defs/scope"},
    "evaluated_step": {"type": "integer", "minimum": 0},
    "valid_until_step": {"type": "integer", "minimum": 0},
    "admitted": {"type": "boolean"},
    "decision": {"enum": ["admitted", "denied"]},
    "p_blocked": {"type": "number", "minimum": 0, "maximum": 1},
    "prediction_set": {
      "type": "array", "minItems": 1, "maxItems": 2, "uniqueItems": true,
      "items": {"enum": ["clear", "blocked"]}
    },
    "calibration_artifact_id": {"type": "string", "minLength": 1},
    "calibration_applicable": {"type": "boolean"},
    "clauses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["clause", "required", "actual", "passed"],
        "properties": {
          "clause": {"type": "string", "minLength": 1},
          "required": true,
          "actual": true,
          "passed": {"type": "boolean"}
        }
      }
    },
    "used_claim_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "discounted_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim_id", "reason"],
        "properties": {
          "claim_id": {"type": "string", "minLength": 1},
          "reason": {"type": "string", "minLength": 1}
        }
      }
    },
    "measurement_root_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "device_root_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "unresolved_conflicts": {"type": "integer", "minimum": 0},
    "belief_gaps": {"type": "array", "items": {"$ref": "belief_gap_v1.schema.json"}},
    "assumptions": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "receipt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
