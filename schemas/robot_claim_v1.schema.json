{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://look-twice.dev/schemas/robot_claim_v1.schema.json",
  "title": "Look Twice Robot Claim v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "claim_id", "fact_id", "predicate", "value",
    "confidence", "observed_step", "valid_until_step", "modality",
    "device_root_id", "capture_root_id", "calibration_id", "pose_version",
    "model_id", "artifact_sha256", "parent_claim_ids", "quality",
    "visibility", "temporal_skew", "scope"
  ],
  "properties": {
    "schema_version": {"const": "look-twice.robot-claim/v1"},
    "claim_id": {"type": "string", "minLength": 1},
    "fact_id": {"type": "string", "minLength": 1},
    "predicate": {"type": "string", "minLength": 1},
    "value": {"enum": ["clear", "blocked", "inconclusive"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "observed_step": {"type": "integer", "minimum": 0},
    "valid_until_step": {"type": "integer", "minimum": 0},
    "modality": {"type": "string", "minLength": 1},
    "device_root_id": {"type": "string"},
    "capture_root_id": {"type": "string"},
    "calibration_id": {"type": "string"},
    "pose_version": {"type": "string"},
    "model_id": {"type": "string"},
    "artifact_sha256": {
      "type": "string",
      "pattern": "^$|^[0-9a-f]{64}$"
    },
    "parent_claim_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "quality": {"type": "number", "minimum": 0, "maximum": 1},
    "visibility": {"type": "number", "minimum": 0, "maximum": 1},
    "temporal_skew": {"type": "integer", "minimum": 0},
    "scope": {"$ref": "#/$defs/scope"}
  },
  "$defs": {
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["robot_id", "payload_id", "region_id"],
      "properties": {
        "robot_id": {"type": "string", "minLength": 1},
        "payload_id": {"type": "string", "minLength": 1},
        "region_id": {"type": "string", "minLength": 1}
      }
    }
  }
}
