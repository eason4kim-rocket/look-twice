<?xml version="1.0"?>
<robot name="look_twice_skid_steer">
  <!-- v5: wheel links include explicit CoM origins so Genesis does not drop inertia. -->
  <material name="look_twice_blue">
    <color rgba="0.10 0.45 0.95 1.0"/>
  </material>
  <material name="wheel_dark">
    <color rgba="0.08 0.08 0.10 1.0"/>
  </material>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="10.0"/>
      <inertia ixx="0.090" ixy="0" ixz="0" iyy="0.140" iyz="0" izz="0.180"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><box size="0.42 0.32 0.14"/></geometry>
      <material name="look_twice_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry><box size="0.42 0.32 0.14"/></geometry>
    </collision>
  </link>

  <link name="sensor_mast">
    <inertial>
      <origin xyz="0 0 0.13"/>
      <mass value="0.4"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.13"/>
      <geometry><box size="0.04 0.04 0.26"/></geometry>
      <material name="look_twice_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.13"/>
      <geometry><box size="0.04 0.04 0.26"/></geometry>
    </collision>
  </link>
  <joint name="sensor_mast_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="sensor_mast"/>
    <origin xyz="0.10 0 0.07"/>
  </joint>

  <!-- Simplified arm mast for proxy grasp (fixed geometry; grasp is logical attach). -->
  <link name="arm_link">
    <inertial>
      <origin xyz="0.12 0 0"/>
      <mass value="0.6"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.008"/>
    </inertial>
    <visual>
      <origin xyz="0.12 0 0"/>
      <geometry><box size="0.24 0.04 0.04"/></geometry>
      <material name="look_twice_blue"/>
    </visual>
    <collision>
      <origin xyz="0.12 0 0"/>
      <geometry><box size="0.24 0.04 0.04"/></geometry>
    </collision>
  </link>
  <joint name="arm_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="arm_link"/>
    <origin xyz="0.15 0 0.05"/>
  </joint>

  <link name="left_front_wheel">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.40"/>
      <inertia ixx="0.0010" ixy="0" ixz="0" iyy="0.0010" iyz="0" izz="0.0006"/>
    </inertial>
    <visual><origin rpy="1.5707963 0 0"/><geometry><cylinder radius="0.07" length="0.05"/></geometry><material name="wheel_dark"/></visual>
    <collision><origin rpy="1.5707963 0 0"/><geometry><cylinder radius="0.07" length="0.05"/></geometry></collision>
  </link>
  <joint name="left_front_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="left_front_wheel"/>
    <origin xyz="0.13 0.18 -0.05"/><axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0.02"/><limit effort="30" velocity="25"/>
  </joint>

  <link name="left_rear_wheel">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.40"/>
      <inertia ixx="0.0010" ixy="0" ixz="0" iyy="0.0010" iyz="0" izz="0.0006"/>
    </inertial>
    <visual><origin rpy="1.5707963 0 0"/><geometry><cylinder radius="0.07" length="0.05"/></geometry><material name="wheel_dark"/></visual>
    <collision><origin rpy="1.5707963 0 0"/><geometry><cylinder radius="0.07" length="0.05"/></geometry></collision>
  </link>
  <joint name="left_rear_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="left_rear_wheel"/>
    <origin xyz="-0.13 0.18 -0.05"/><axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0.02"/><limit effort="30" velocity="25"/>
  </joint>

  <link name="right_front_wheel">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.40"/>
      <inertia ixx="0.0010" ixy="0" ixz="0" iyy="0.0010" iyz="0" izz="0.0006"/>
    </inertial>
    <visual><origin rpy="1.5707963 0 0"/><geometry><cylinder radius="0.07" length="0.05"/></geometry><material name="wheel_dark"/></visual>
    <collision><origin rpy="1.5707963 0 0"/><geometry><cylinder radius="0.07" length="0.05"/></geometry></collision>
  </link>
  <joint name="right_front_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="right_front_wheel"/>
    <origin xyz="0.13 -0.18 -0.05"/><axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0.02"/><limit effort="30" velocity="25"/>
  </joint>

  <link name="right_rear_wheel">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.40"/>
      <inertia ixx="0.0010" ixy="0" ixz="0" iyy="0.0010" iyz="0" izz="0.0006"/>
    </inertial>
    <visual><origin rpy="1.5707963 0 0"/><geometry><cylinder radius="0.07" length="0.05"/></geometry><material name="wheel_dark"/></visual>
    <collision><origin rpy="1.5707963 0 0"/><geometry><cylinder radius="0.07" length="0.05"/></geometry></collision>
  </link>
  <joint name="right_rear_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="right_rear_wheel"/>
    <origin xyz="-0.13 -0.18 -0.05"/><axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0.02"/><limit effort="30" velocity="25"/>
  </joint>
</robot>
